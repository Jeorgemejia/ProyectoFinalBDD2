@model IEnumerable<BancaCore.Models.Tarjeta>
@{ ViewData["Title"] = "Tarjetas"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="page-title mb-0">Tarjetas</h5>
    <a asp-action="Crear" class="btn btn-banca btn-sm">Nueva Tarjeta</a>
</div>

<div class="card">
    <div class="p-3 border-bottom d-flex gap-2">
        <input id="buscar" class="form-control form-control-sm" style="max-width:360px" placeholder="Buscar por n˙mero, cliente" />
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead><tr><th>N░ Tarjeta</th><th>Cuenta</th><th>Tipo</th><th>Cliente</th><th>Vence</th><th></th></tr></thead>
            <tbody>
            @foreach(var t in Model){
                <tr>
                    <td class="font-monospace">@t.NumeroTarjeta</td>
                    <td>@t.NumeroCuenta</td>
                    <td>@t.NombreTipoTarjeta</td>
                    <td>@t.NombreCliente</td>
                    <td>@(t.LimiteCredito.HasValue ? t.LimiteCredito.Value.ToString("N2") : "-")</td>
                    <td>@(t.SaldoUtilizado.HasValue ? t.SaldoUtilizado.Value.ToString("N2") : "-")</td>
                    <td>@t.FechaEmision.ToString("dd/MM/yyyy")</td>
                    <td>@t.FechaVencimiento.ToString("dd/MM/yyyy")</td>
                    <td><span class="badge @(t.Estado ? "bg-success" : "bg-secondary")">@(t.Estado ? "Activo" : "Inactivo")</span></td>
                    <td>
                        <a asp-action="Detalle" asp-route-id="@t.CodigoTarjeta" class="btn btn-sm btn-outline-primary me-1">Detalle</a>
                        <a asp-action="Editar" asp-route-id="@t.CodigoTarjeta" class="btn btn-sm btn-outline-secondary me-1">Editar</a>
                        <a asp-action="ConfirmarEliminar" asp-route-id="@t.CodigoTarjeta" class="btn btn-sm btn-outline-danger">Eliminar</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

@section Scripts{
<script>
document.getElementById('buscar').addEventListener('keyup', ()=>{ const q=document.getElementById('buscar').value.toLowerCase(); document.querySelectorAll('table tbody tr').forEach(r=> r.style.display=r.textContent.toLowerCase().includes(q)?'':'none'); });
</script>
}
