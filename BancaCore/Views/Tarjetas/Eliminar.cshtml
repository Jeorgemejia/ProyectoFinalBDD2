@model BancaCore.Models.Tarjeta
@{ ViewData["Title"] = "Eliminar Tarjeta"; }

<div class="card" style="max-width:700px">
 <div class="card-body p-4">
  <p>¿Eliminar tarjeta <strong>@Model.NumeroTarjeta</strong>?</p>
  <form asp-action="Eliminar" method="post">@Html.AntiForgeryToken()
  <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
  <input type="hidden" name="id" value="@Model.CodigoTarjeta" />
  <div class="mt-3"><button class="btn btn-danger">Eliminar</button> <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a></div>
  </form>
 </div>
</div>
