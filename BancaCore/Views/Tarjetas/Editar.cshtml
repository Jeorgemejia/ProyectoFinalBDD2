@model BancaCore.Models.Tarjeta
@{ ViewData["Title"] = "Editar Tarjeta"; }

<div class="card" style="max-width:760px">
 <div class="card-body p-4">
  <form asp-action="Editar" method="post">@Html.AntiForgeryToken()
  <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
  <input type="hidden" asp-for="CodigoTarjeta" />
    <div class="row g-3">
      <div class="col-md-6"><label asp-for="NumeroTarjeta" class="form-label"></label><input asp-for="NumeroTarjeta" class="form-control"/></div>
      <div class="col-md-6"><label asp-for="CodigoCuenta" class="form-label">Cuenta</label><select asp-for="CodigoCuenta" asp-items="ViewBag.Cuentas" class="form-select"></select></div>
      <div class="col-md-6"><label asp-for="CodigoTipoTarjeta" class="form-label">Tipo</label><select asp-for="CodigoTipoTarjeta" asp-items="ViewBag.Tipos" class="form-select"></select></div>
      <div class="col-md-3"><label asp-for="LimiteCredito" class="form-label"></label><input asp-for="LimiteCredito" class="form-control"/></div>
      <div class="col-md-3"><label asp-for="SaldoUtilizado" class="form-label"></label><input asp-for="SaldoUtilizado" class="form-control"/></div>
      <div class="col-md-6"><label asp-for="FechaEmision" class="form-label"></label><input asp-for="FechaEmision" type="date" class="form-control"/></div>
      <div class="col-md-6"><label asp-for="FechaVencimiento" class="form-label"></label><input asp-for="FechaVencimiento" type="date" class="form-control"/></div>
    </div>
    <div class="mt-3"><button class="btn btn-banca">Guardar</button> <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a></div>
  </form>
 </div>
</div>
