@model BancaCore.Models.TipoTarjeta
@{ ViewData["Title"] = "Editar Tipo de Tarjeta"; }

<div class="card" style="max-width:700px">
 <div class="card-body p-4">
  <form asp-action="Editar" method="post">@Html.AntiForgeryToken()
  <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
  <input type="hidden" asp-for="CodigoTipoTarjeta" />
    <div class="mb-3"><label asp-for="Nombre" class="form-label"></label><input asp-for="Nombre" class="form-control"/></div>
    <div class="mb-3">
      <label asp-for="Estado" class="form-label"></label>
      <select asp-for="Estado" class="form-select">
        <option value="true">Activo</option>
        <option value="false">Inactivo</option>
      </select>
    </div>
    <div class="mt-3"><button class="btn btn-banca">Guardar</button> <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a></div>
  </form>
 </div>
</div>
