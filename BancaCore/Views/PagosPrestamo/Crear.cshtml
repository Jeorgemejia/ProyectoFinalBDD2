@model BancaCore.Models.PagoPrestamo
@{ ViewData["Title"] = "Registrar Pago de Préstamo"; }

<div class="card" style="max-width:760px">
 <div class="card-body p-4">
  <form asp-action="Crear" method="post">@Html.AntiForgeryToken()
    <div class="row g-3">
      <div class="col-md-6"><label class="form-label">Préstamo</label><select asp-for="CodigoPrestamo" asp-items="ViewBag.Prestamos" class="form-select"></select></div>
      <div class="col-md-6"><label class="form-label">Transacción</label><select asp-for="CodigoTransaccion" asp-items="ViewBag.Transacciones" class="form-select"></select></div>
      <div class="col-md-6"><label asp-for="MontoCapital" class="form-label"></label><input asp-for="MontoCapital" class="form-control"/></div>
      <div class="col-md-6"><label asp-for="MontoInteres" class="form-label"></label><input asp-for="MontoInteres" class="form-control"/></div>
      <div class="col-md-6"><label asp-for="FechaPago" class="form-label"></label><input asp-for="FechaPago" type="date" class="form-control"/></div>
    </div>
    <div class="mt-3"><button class="btn btn-banca">Guardar</button> <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a></div>
  </form>
 </div>
</div>
