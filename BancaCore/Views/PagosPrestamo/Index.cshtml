@model IEnumerable<BancaCore.Models.PagoPrestamo>
@{ ViewData["Title"] = "Pagos de Préstamos"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="page-title mb-0">Pagos de Préstamos</h5>
    <a asp-action="Crear" class="btn btn-banca btn-sm">Registrar Pago</a>
</div>

<div class="card">
    <div class="p-3 border-bottom d-flex gap-2">
        <input id="buscarPagosPrestamo" type="text" class="form-control form-control-sm" style="max-width:360px" placeholder="Buscar por préstamo, monto, fecha..." />
        <button id="btnMostrarTodosPagosPrestamo" type="button" class="btn btn-outline-secondary btn-sm">Mostrar todos</button>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead><tr><th>#</th><th>Préstamo</th><th>Monto Capital</th><th>Monto Interés</th><th>Fecha</th></tr></thead>
            <tbody>
            @foreach(var p in Model){
                <tr>
                    <td class="small text-muted">#@p.CodigoPagoPrestamo</td>
                    <td>@p.CodigoPrestamo</td>
                    <td>@p.MontoCapital.ToString("N2")</td>
                    <td>@p.MontoInteres.ToString("N2")</td>
                    <td>@p.FechaPago.ToString("dd/MM/yyyy")</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

@section Scripts{
<script>
document.getElementById('buscarPagosPrestamo').addEventListener('keyup', ()=>{
    const q = document.getElementById('buscarPagosPrestamo').value.toLowerCase();
    document.querySelectorAll('table tbody tr').forEach(r=> r.style.display = r.textContent.toLowerCase().includes(q)?'':'none');
});
document.getElementById('btnMostrarTodosPagosPrestamo').addEventListener('click', ()=>{ document.getElementById('buscarPagosPrestamo').value=''; document.getElementById('buscarPagosPrestamo').dispatchEvent(new Event('keyup')); });
</script>
}
