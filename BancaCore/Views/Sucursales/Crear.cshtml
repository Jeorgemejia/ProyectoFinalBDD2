@* Sucursales/Crear.cshtml *@
@model BancaCore.Models.Sucursal
@{ ViewData["Title"] = "Nueva Sucursal"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="page-title mb-0"><i class="bi bi-building me-2"></i>Nueva Sucursal</h5>
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Volver</a>
</div>

<div class="card" style="max-width:520px">
    <div class="card-body p-4">
        <form asp-action="Crear" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label asp-for="Nombre" class="form-label fw-semibold"></label>
                <input asp-for="Nombre" class="form-control" placeholder="Nombre de la sucursal"/>
                <span asp-validation-for="Nombre" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Direccion" class="form-label fw-semibold"></label>
                <input asp-for="Direccion" class="form-control" placeholder="Dirección completa"/>
                <span asp-validation-for="Direccion" class="text-danger small"></span>
            </div>
            <div class="mb-4">
                <label asp-for="Telefono" class="form-label fw-semibold"></label>
                <input asp-for="Telefono" class="form-control" placeholder="Teléfono"/>
                <span asp-validation-for="Telefono" class="text-danger small"></span>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-banca"><i class="bi bi-check-lg me-1"></i>Guardar</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>
