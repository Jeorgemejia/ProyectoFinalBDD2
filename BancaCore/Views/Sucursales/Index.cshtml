@* Sucursales/Index.cshtml *@
@model IEnumerable<BancaCore.Models.Sucursal>
@{ ViewData["Title"] = "Sucursales"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="page-title mb-0"><i class="bi bi-building me-2"></i>Sucursales</h5>
    <a asp-action="Crear" class="btn btn-banca btn-sm"><i class="bi bi-plus-circle me-1"></i>Nueva Sucursal</a>
</div>

@{ var lista = Model as IEnumerable<BancaCore.Models.Sucursal>; var total = lista?.Count() ?? 0; }
@if (!string.IsNullOrWhiteSpace((string)ViewBag.Query))
{
    <div class="mb-2"><strong>Resultados para "@ViewBag.Query":</strong> @total registros</div>
}
else
{
    <div class="mb-2"><strong>Total sucursales:</strong> @total registros</div>
}

<div class="p-3 border-bottom d-flex gap-2 mb-3">
    <form id="formBuscar" class="d-flex w-100 gap-2" method="get" asp-action="Index" asp-controller="Sucursales">
        <input name="q" id="buscar" value="@(ViewBag.Query ?? "")" type="text" class="form-control form-control-sm" style="max-width:360px" placeholder="Buscar por nombre, direcci¾n, telķfono..." />
        <button type="submit" class="btn btn-banca btn-sm">Buscar</button>
        <button id="btnMostrarTodos" type="button" class="btn btn-outline-secondary btn-sm">Mostrar todos</button>
    </form>
</div>

@section Scripts {
<script>
document.getElementById('btnMostrarTodos').addEventListener('click', ()=>{
    document.getElementById('buscar').value='';
    var f = document.getElementById('formBuscar');
    if(f) f.submit();
});
// Ensure form submission navigates even if taghelpers or other scripts interfere
(function(){
    var f = document.getElementById('formBuscar');
    if(!f) return;
    f.addEventListener('submit', function(e){
        // allow normal submit when browser will handle it, but force navigation if something blocks
        try{
            var v = document.getElementById('buscar').value || '';
            var path = window.location.pathname;
            var qs = v ? ('?q=' + encodeURIComponent(v)) : '';
            // navigate explicitly
            window.location.href = path + qs;
            e.preventDefault();
        }catch(err){
            // fallback to default submit
        }
    });
})();
</script>
}

<div class="row g-3">
@foreach (var s in Model)
{
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <h6 class="fw-bold"><i class="bi bi-building me-2 text-primary"></i>@s.Nombre</h6>
                <p class="text-muted small mb-1"><i class="bi bi-geo-alt me-1"></i>@s.Direccion</p>
                <p class="text-muted small mb-2"><i class="bi bi-telephone me-1"></i>@s.Telefono</p>
                <span class="badge @(s.Estado ? "bg-success" : "bg-secondary")">
                    @(s.Estado ? "Activa" : "Inactiva")
                </span>
            </div>
            <div class="card-footer bg-transparent border-0 d-flex gap-2">
                <a asp-action="Editar" asp-route-id="@s.CodigoSucursal" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-pencil me-1"></i>Editar
                </a>
                <a asp-action="ConfirmarEliminar" asp-route-id="@s.CodigoSucursal" class="btn btn-sm btn-outline-danger">
                    <i class="bi bi-trash me-1"></i>Eliminar
                </a>
            </div>
        </div>
    </div>
}
</div>
