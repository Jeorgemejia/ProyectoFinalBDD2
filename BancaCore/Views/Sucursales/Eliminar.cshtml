@* Views/Sucursales/Eliminar.cshtml *@
@model BancaCore.Models.Sucursal
@{ ViewData["Title"] = "Eliminar Sucursal"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="page-title mb-0"><i class="bi bi-trash me-2"></i>Eliminar Sucursal</h5>
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Volver</a>
</div>

<div class="card" style="max-width:780px">
    <div class="card-body">
        <p>¿Está seguro que desea eliminar la sucursal <strong>@Model.Nombre</strong>?</p>
        <form asp-action="Eliminar" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.CodigoSucursal" />
            <div class="mt-3">
                <button type="submit" class="btn btn-danger me-2">Eliminar</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>
