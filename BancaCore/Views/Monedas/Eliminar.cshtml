@model BancaCore.Models.Moneda
@{ ViewData["Title"] = "Eliminar Moneda"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="page-title mb-0">Eliminar Moneda</h5>
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Volver</a>
</div>

<div class="card" style="max-width:700px">
    <div class="card-body p-4">
        <p>żEliminar moneda <strong>@Model.Nombre</strong>?</p>
        <form asp-action="Eliminar" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.CodigoMoneda" />
            <div class="mt-3">
                <button class="btn btn-danger">Eliminar</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>
