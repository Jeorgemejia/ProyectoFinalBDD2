@model IEnumerable<BancaCore.Models.Moneda>
@{ ViewData["Title"] = "Monedas"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="page-title mb-0"><i class="bi bi-currency-exchange me-2"></i>Monedas</h5>
    <a asp-action="Crear" class="btn btn-banca btn-sm"><i class="bi bi-plus-circle me-1"></i>Nueva Moneda</a>
</div>

<div class="card">
    <div class="p-3 border-bottom d-flex gap-2">
        <input id="buscar" class="form-control form-control-sm" style="max-width:360px" placeholder="Buscar por nombre o símbolo" />
        <button id="btnMostrarTodos" class="btn btn-outline-secondary btn-sm">Mostrar todos</button>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead><tr><th>Nombre</th><th>Símbolo</th><th>Tipo Cambio</th><th></th></tr></thead>
            <tbody>
            @foreach(var m in Model){
                <tr>
                    <td>@m.Nombre</td>
                    <td>@m.Simbolo</td>
                    <td>@m.TipoCambio.ToString("N4")</td>
                    <td>
                        <span class="badge @(m.Estado ? "bg-success" : "bg-secondary")">@(m.Estado ? "Activo" : "Inactivo")</span>
                    </td>
                    <td>
                        <a asp-action="Editar" asp-route-id="@m.CodigoMoneda" class="btn btn-sm btn-outline-secondary me-1">Editar</a>
                        <a asp-action="ConfirmarEliminar" asp-route-id="@m.CodigoMoneda" class="btn btn-sm btn-outline-danger">Eliminar</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
function filtrar(){
    const q = document.getElementById('buscar').value.toLowerCase();
    document.querySelectorAll('table tbody tr').forEach(r=>{ r.style.display = r.textContent.toLowerCase().includes(q) ? '' : 'none'; });
}
document.getElementById('buscar').addEventListener('keyup', filtrar);
document.getElementById('btnMostrarTodos').addEventListener('click', ()=>{ document.getElementById('buscar').value=''; filtrar(); });
</script>
}
