@model BancaCore.Models.Moneda
@{ ViewData["Title"] = "Editar Moneda"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="page-title mb-0">Editar Moneda</h5>
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Volver</a>
</div>

<div class="card" style="max-width:700px">
    <div class="card-body p-4">
        <form asp-action="Editar" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
            <input type="hidden" asp-for="CodigoMoneda" />
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Nombre" class="form-label"></label>
                    <input asp-for="Nombre" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label asp-for="Simbolo" class="form-label"></label>
                    <input asp-for="Simbolo" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label asp-for="TipoCambio" class="form-label"></label>
                    <input asp-for="TipoCambio" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label asp-for="Estado" class="form-label"></label>
                    <select asp-for="Estado" class="form-select">
                        <option value="true">Activo</option>
                        <option value="false">Inactivo</option>
                    </select>
                </div>
            </div>
            <div class="mt-4">
                <button class="btn btn-banca">Guardar</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>
