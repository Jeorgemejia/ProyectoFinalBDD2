@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="page-title mb-0"><i class="bi bi-speedometer2 me-2"></i>Dashboard</h5>
        <small class="text-muted">Resumen operativo del sistema bancario</small>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card blue p-3">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-muted small">Clientes Activos</div>
                    <div class="fs-3 fw-bold" style="color:#0d2b6e">@ViewBag.TotalClientes</div>
                </div>
                <i class="bi bi-people fs-1 opacity-15" style="color:#0d2b6e"></i>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card green p-3">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-muted small">Cuentas Activas</div>
                    <div class="fs-3 fw-bold text-success">@ViewBag.TotalCuentas</div>
                </div>
                <i class="bi bi-credit-card-2-front fs-1 opacity-15 text-success"></i>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card gold p-3">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-muted small">Saldo Total</div>
                    <div class="fs-4 fw-bold" style="color:#92400e">Q @string.Format("{0:N2}", ViewBag.TotalSaldos)</div>
                </div>
                <i class="bi bi-safe fs-1 opacity-15" style="color:#92400e"></i>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card red p-3">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-muted small">Transacciones Hoy</div>
                    <div class="fs-3 fw-bold text-danger">@ViewBag.TransaccionesHoy</div>
                </div>
                <i class="bi bi-arrow-left-right fs-1 opacity-15 text-danger"></i>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header bg-white border-0 pt-3 pb-2">
                <h6 class="fw-bold mb-0"><i class="bi bi-clock-history me-2 text-primary"></i>Últimas Transacciones</h6>
            </div>
            <div class="card-body p-0">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Tipo</th>
                            <th>Cuenta</th>
                            <th class="text-end">Monto</th>
                            <th>Fecha/Hora</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in (IEnumerable<dynamic>)ViewBag.UltimasTransacciones)
                        {
                            string badge = t.Tipo switch
                            {
                                "Depósito" => "badge-dep",
                                "Retiro" => "badge-ret",
                                "Transferencia" => "badge-tra",
                                _ => "badge-pag"
                            };
                            <tr>
                                <td class="text-muted small">#@t.CodigoTransaccion</td>
                                <td><span class="badge @badge px-2 py-1">@t.Tipo</span></td>
                                <td class="font-monospace small">@(t.CuentaOrigen ?? "—")</td>
                                <td class="text-end fw-bold">@t.Simbolo @string.Format("{0:N2}", t.Monto)</td>
                                <td class="small text-muted">@((DateTime)t.FechaHora).ToString("dd/MM/yy HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header bg-white border-0 pt-3 pb-2">
                <h6 class="fw-bold mb-0"><i class="bi bi-lightning-charge me-2 text-warning"></i>Operaciones Rápidas</h6>
            </div>
            <div class="card-body d-flex flex-column gap-2">
                <a asp-controller="Clientes" asp-action="Crear" class="btn btn-outline-primary text-start"><i class="bi bi-person-plus me-2"></i>Nuevo Cliente</a>
                <a asp-controller="Cuentas" asp-action="Crear" class="btn btn-outline-secondary text-start"><i class="bi bi-plus-circle me-2"></i>Abrir Cuenta</a>
                <a asp-controller="Prestamos" asp-action="Crear" class="btn btn-outline-warning text-start"><i class="bi bi-cash-coin me-2"></i>Nuevo Préstamo</a>
                <hr class="my-1" />
                <a asp-controller="Transacciones" asp-action="Deposito" class="btn btn-outline-success text-start"><i class="bi bi-arrow-down-circle me-2"></i>Depósito</a>
                <a asp-controller="Transacciones" asp-action="Retiro" class="btn btn-outline-danger text-start"><i class="bi bi-arrow-up-circle me-2"></i>Retiro</a>
                <a asp-controller="Transacciones" asp-action="Transferencia" class="btn btn-outline-info text-start"><i class="bi bi-arrow-left-right me-2"></i>Transferencia</a>
            </div>
        </div>
    </div>
</div>