@model BancaCore.Models.UsuarioSistema
@{ ViewData["Title"] = "Eliminar Usuario"; }

<div class="card" style="max-width:700px">
 <div class="card-body p-4">
  <p>¿Eliminar usuario <strong>@Model.Usuario</strong>?</p>
  <form asp-action="Eliminar" method="post">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.CodigoUsuario" />
  <div class="mt-3"><button class="btn btn-danger">Eliminar</button> <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a></div>
  </form>
 </div>
</div>
