@model BancaCore.Models.UsuarioSistema
@{ ViewData["Title"] = "Editar Usuario"; }

<div class="card" style="max-width:760px">
 <div class="card-body p-4">
  <form asp-action="Editar" method="post">@Html.AntiForgeryToken()<input type="hidden" asp-for="CodigoUsuario" />
    <div class="row g-3">
      <div class="col-md-6"><label asp-for="Usuario" class="form-label"></label><input asp-for="Usuario" class="form-control"/></div>
      <div class="col-md-6"><label asp-for="ContraseÒa" class="form-label"></label><input asp-for="ContraseÒa" class="form-control"/></div>
      <div class="col-md-6"><label asp-for="CorreoRecuperacion" class="form-label"></label><input asp-for="CorreoRecuperacion" class="form-control"/></div>
      <div class="col-md-3"><label asp-for="Rol" class="form-label"></label><input asp-for="Rol" class="form-control"/></div>
      <div class="col-md-3"><label asp-for="CodigoSucursal" class="form-label">Sucursal</label><select asp-for="CodigoSucursal" asp-items="ViewBag.Sucursales" class="form-select"></select></div>
    </div>
    <div class="mt-3"><button class="btn btn-banca">Guardar</button> <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a></div>
  </form>
 </div>
</div>
