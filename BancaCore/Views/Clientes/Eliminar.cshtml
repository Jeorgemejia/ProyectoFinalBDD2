@* Views/Clientes/Eliminar.cshtml *@
@model Cliente
@{ ViewData["Title"] = "Eliminar Cliente"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="page-title mb-0"><i class="bi bi-person-x me-2"></i>Desactivar Cliente</h5>
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Volver</a>
</div>

<div class="card" style="max-width:780px">
    <div class="card-body">
        <p>┐Estß seguro que desea desactivar el cliente <strong>@Model.NombreCompleto</strong> (ID: @Model.IdCliente)?</p>
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

        <form asp-action="Eliminar" method="post">
            <input type="hidden" name="id" value="@Model.IdCliente" />
            <button type="submit" class="btn btn-danger">Confirmar eliminaciˇn</button>
        </form>
    </div>
</div>
