@* Views/Clientes/Detalle.cshtml *@
@model Cliente
@{ ViewData["Title"] = "Detalle Cliente"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="page-title mb-0"><i class="bi bi-eye me-2"></i>Detalle Cliente</h5>
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Volver</a>
</div>

<div class="card" style="max-width:780px">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Nombre completo</dt>
            <dd class="col-sm-9">@Model.NombreCompleto</dd>

            <dt class="col-sm-3">Tipo</dt>
            <dd class="col-sm-9">@Model.TipoCliente</dd>

            <dt class="col-sm-3">DPI / NIT</dt>
            <dd class="col-sm-9">@(Model.DPI ?? Model.NIT ?? "—")</dd>

            <dt class="col-sm-3">Fecha de nacimiento</dt>
            <dd class="col-sm-9">@Model.FechaNacimiento.ToString("dd/MM/yyyy")</dd>

            <dt class="col-sm-3">Teléfono</dt>
            <dd class="col-sm-9">@Model.Telefono</dd>

            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Email</dd>

            <dt class="col-sm-3">Dirección</dt>
            <dd class="col-sm-9">@Model.Direccion</dd>

            <dt class="col-sm-3">Registro</dt>
            <dd class="col-sm-9">@Model.FechaCreacion?.ToString("dd/MM/yyyy")</dd>
        </dl>
        <div class="mt-3">
            <a asp-action="Editar" asp-route-id="@Model.IdCliente" class="btn btn-sm btn-outline-secondary me-1">Editar</a>
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Volver</a>
        </div>
    </div>
</div>
