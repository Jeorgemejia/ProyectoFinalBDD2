@* Views/Cuentas/Eliminar.cshtml *@
@model CuentaBancaria
@{ ViewData["Title"] = "Cerrar Cuenta"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="page-title mb-0"><i class="bi bi-x-circle me-2"></i>Cerrar Cuenta</h5>
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Volver</a>
</div>

<div class="card" style="max-width:780px">
    <div class="card-body">
        <p>¿Está seguro que desea cerrar la cuenta <strong>@Model.NumeroCuenta</strong> perteneciente a <strong>@Model.NombreCliente</strong>?</p>
        <form asp-action="Cerrar" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.CodigoCuenta" />
            <div class="mt-3">
                <button type="submit" class="btn btn-danger me-2">Cerrar cuenta</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>
