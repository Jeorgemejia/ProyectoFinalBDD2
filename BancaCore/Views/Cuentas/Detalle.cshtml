@* Views/Cuentas/Detalle.cshtml *@
@model CuentaBancaria
@{ ViewData["Title"] = "Detalle Cuenta"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="page-title mb-0"><i class="bi bi-eye me-2"></i>Detalle Cuenta</h5>
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Volver</a>
</div>

<div class="card mb-3" style="max-width:900px">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">N·mero de cuenta</dt>
            <dd class="col-sm-9 font-monospace fw-bold">@Model.NumeroCuenta</dd>

            <dt class="col-sm-3">Cliente</dt>
            <dd class="col-sm-9">@Model.NombreCliente</dd>

            <dt class="col-sm-3">Tipo de cuenta</dt>
            <dd class="col-sm-9">@Model.NombreTipoCuenta</dd>

            <dt class="col-sm-3">Sucursal</dt>
            <dd class="col-sm-9">@Model.NombreSucursal</dd>

            <dt class="col-sm-3">Moneda</dt>
            <dd class="col-sm-9">@Model.SimboloMoneda</dd>

            <dt class="col-sm-3">Saldo actual</dt>
            <dd class="col-sm-9">@Model.SimboloMoneda @Model.SaldoActual.ToString("N2")</dd>

            <dt class="col-sm-3">Fecha apertura</dt>
            <dd class="col-sm-9">@Model.FechaApertura.ToString("dd/MM/yyyy")</dd>

            <dt class="col-sm-3">Estado</dt>
            <dd class="col-sm-9">@(Model.Estado ? "Activa" : "Cerrada")</dd>
        </dl>

        <div class="mt-3">
            <a asp-action="Editar" asp-route-id="@Model.CodigoCuenta" class="btn btn-sm btn-outline-secondary me-1">Editar</a>
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Volver</a>
        </div>
    </div>
</div>

<div class="card" style="max-width:900px">
    <div class="card-body">
        <h6 class="fw-semibold">┌ltimas transacciones</h6>
        <table class="table table-sm mt-2">
            <thead><tr><th>Fecha</th><th>Tipo</th><th>Cuenta origen</th><th>Monto</th><th>Descripci¾n</th></tr></thead>
            <tbody>
                @if (ViewBag.Transacciones != null)
                {
                    foreach (var t in ViewBag.Transacciones as IEnumerable<Transaccion>)
                    {
                        <tr>
                            <td class="small text-muted">@t.FechaHora.ToString("dd/MM/yyyy")</td>
                            <td class="small">@t.NombreTipoTransaccion</td>
                            <td class="small">@t.NumeroCuentaOrigen</td>
                            <td class="small">@t.SimboloMoneda @t.Monto.ToString("N2")</td>
                            <td class="small text-muted">@t.Descripcion</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
