@* Prestamos/Detalle.cshtml *@
@model BancaCore.Models.Prestamo
@{ ViewData["Title"] = "Detalle Préstamo"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="page-title mb-0"><i class="bi bi-cash-coin me-2"></i>Detalle del Préstamo</h5>
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Volver</a>
</div>

<div class="card" style="max-width:600px">
    <div class="card-body p-4">
        <div class="row g-3">
            <div class="col-md-6">
                <div class="text-muted small">Cliente</div>
                <div class="fw-bold">@Model.NombreCliente</div>
            </div>
            <div class="col-md-6">
                <div class="text-muted small">Tipo de Préstamo</div>
                <div class="fw-bold">@Model.NombreTipoPrestamo</div>
            </div>
            <div class="col-md-6">
                <div class="text-muted small">Monto Solicitado</div>
                <div class="fw-bold fs-5">@Model.SimboloMoneda @Model.MontoSolicitado.ToString("N2")</div>
            </div>
            <div class="col-md-6">
                <div class="text-muted small">Saldo Pendiente</div>
                <div class="fw-bold fs-5 text-danger">@Model.SimboloMoneda @Model.SaldoPendiente.ToString("N2")</div>
            </div>
            <div class="col-md-4">
                <div class="text-muted small">Tasa de Interés</div>
                <div class="fw-bold">@Model.TasaInteres%</div>
            </div>
            <div class="col-md-4">
                <div class="text-muted small">Plazo</div>
                <div class="fw-bold">@Model.PlazoMeses meses</div>
            </div>
            <div class="col-md-4">
                <div class="text-muted small">Fecha Desembolso</div>
                <div class="fw-bold">@Model.FechaDesembolso.ToString("dd/MM/yyyy")</div>
            </div>
            <div class="col-12">
                <div class="text-muted small mb-1">Progreso de pago</div>
                @{
                    var pagado = Model.MontoSolicitado - Model.SaldoPendiente;
                    var pct = Model.MontoSolicitado > 0 ? (int)((pagado / Model.MontoSolicitado) * 100) : 0;
                }
                <div class="progress" style="height:20px">
                    <div class="progress-bar bg-success" style="width:@pct%">@pct%</div>
                </div>
                <small class="text-muted">Pagado: @Model.SimboloMoneda @pagado.ToString("N2") de @Model.SimboloMoneda @Model.MontoSolicitado.ToString("N2")</small>
            </div>
        </div>
    </div>
</div>
