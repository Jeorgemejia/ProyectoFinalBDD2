@* Prestamos/Eliminar.cshtml *@
@model BancaCore.Models.Prestamo
@{ ViewData["Title"] = "Eliminar Préstamo"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="page-title mb-0"><i class="bi bi-person-x me-2"></i>Eliminar Préstamo</h5>
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Volver</a>
</div>

<div class="card" style="max-width:780px">
    <div class="card-body">
        <p>¿Está seguro que desea eliminar el préstamo <strong>#@Model.CodigoPrestamo</strong> del cliente <strong>@Model.NombreCliente</strong>?</p>
        <form asp-action="Eliminar" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.CodigoPrestamo" />
            <div class="mt-3">
                <button type="submit" class="btn btn-danger me-2">Eliminar</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>
