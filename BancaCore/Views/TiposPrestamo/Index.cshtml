@model IEnumerable<BancaCore.Models.TipoPrestamo>
@{ ViewData["Title"] = "Tipos de PrÈstamo"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="page-title mb-0">Tipos de PrÈstamo</h5>
    <a asp-action="Crear" class="btn btn-banca btn-sm">Nuevo</a>
</div>

<div class="card">
    <div class="p-3 border-bottom d-flex gap-2">
        <input id="buscarTiposPrestamo" type="text" class="form-control form-control-sm" style="max-width:360px" placeholder="Buscar por nombre..." />
        <button id="btnMostrarTodosTiposPrestamo" type="button" class="btn btn-outline-secondary btn-sm">Mostrar todos</button>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead><tr><th>Nombre</th><th>Tasa</th><th>Plazo M·x.</th><th></th></tr></thead>
            <tbody>
            @foreach(var t in Model){
                <tr>
                    <td>@t.Nombre</td>
                    <td>@t.TasaInteres.ToString("N2")%</td>
                    <td>@t.PlazoMaximoMeses</td>
                    <td>
                        <a asp-action="Editar" asp-route-id="@t.CodigoTipoPrestamo" class="btn btn-sm btn-outline-secondary">Editar</a>
                        <a asp-action="ConfirmarEliminar" asp-route-id="@t.CodigoTipoPrestamo" class="btn btn-sm btn-outline-danger">Eliminar</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

@section Scripts{
<script>
document.getElementById('buscarTiposPrestamo').addEventListener('keyup', ()=>{
    const q = document.getElementById('buscarTiposPrestamo').value.toLowerCase();
    document.querySelectorAll('table tbody tr').forEach(r=> r.style.display = r.textContent.toLowerCase().includes(q)?'':'none');
});
document.getElementById('btnMostrarTodosTiposPrestamo').addEventListener('click', ()=>{ document.getElementById('buscarTiposPrestamo').value=''; document.getElementById('buscarTiposPrestamo').dispatchEvent(new Event('keyup')); });
</script>
}
