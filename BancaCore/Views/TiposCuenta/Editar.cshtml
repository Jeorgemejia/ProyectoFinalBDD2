@model BancaCore.Models.TipoCuenta
@{ ViewData["Title"] = "Editar Tipo de Cuenta"; }

<div class="card" style="max-width:700px">
 <div class="card-body p-4">
  <form asp-action="Editar" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="CodigoTipoCuenta" />
    <div class="row g-3">
      <div class="col-md-6"><label asp-for="Nombre" class="form-label"></label><input asp-for="Nombre" class="form-control"/></div>
      <div class="col-md-3"><label asp-for="SaldoMinimo" class="form-label"></label><input asp-for="SaldoMinimo" class="form-control"/></div>
      <div class="col-md-3"><label asp-for="TasaInteres" class="form-label"></label><input asp-for="TasaInteres" class="form-control"/></div>
    </div>
    <div class="mt-3"><button class="btn btn-banca">Guardar</button> <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a></div>
  </form>
 </div>
</div>
