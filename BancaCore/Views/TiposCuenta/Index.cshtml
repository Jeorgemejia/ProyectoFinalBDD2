@model IEnumerable<BancaCore.Models.TipoCuenta>
@{ ViewData["Title"] = "Tipos de Cuenta"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="page-title mb-0"><i class="bi bi-list-nested me-2"></i>Tipos de Cuenta</h5>
    <a asp-action="Crear" class="btn btn-banca btn-sm">Nuevo</a>
</div>

<div class="card">
    <div class="p-3 border-bottom d-flex gap-2">
        <input id="buscar" class="form-control form-control-sm" style="max-width:360px" placeholder="Buscar por nombre" />
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead><tr><th>Nombre</th><th>Saldo Mínimo</th><th>Tasa</th><th></th></tr></thead>
            <tbody>
            @foreach(var t in Model){
                <tr>
                    <td>@t.Nombre</td>
                    <td>@t.SaldoMinimo.ToString("N2")</td>
                    <td>@t.TasaInteres.ToString("N2")%</td>
                    <td>
                        <a asp-action="Editar" asp-route-id="@t.CodigoTipoCuenta" class="btn btn-sm btn-outline-secondary">Editar</a>
                        <a asp-action="ConfirmarEliminar" asp-route-id="@t.CodigoTipoCuenta" class="btn btn-sm btn-outline-danger">Eliminar</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

@section Scripts{
<script>
document.getElementById('buscar').addEventListener('keyup', ()=>{
 const q=document.getElementById('buscar').value.toLowerCase();
 document.querySelectorAll('table tbody tr').forEach(r=> r.style.display=r.textContent.toLowerCase().includes(q)?'':'none');
});
</script>
}
